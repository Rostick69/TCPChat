<Window x:Class="Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сервер" Height="480" Width="680"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Порт:"/>
            <TextBox x:Name="txtPort" Text="5000" Width="80"/>
            <Button Content="Запустить" Width="100" Margin="10,0,5,0" Click="BtnStart_Click" x:Name="btnStart"/>
            <Button Content="Остановить" Width="100" Click="BtnStop_Click" IsEnabled="False" x:Name="btnStop"/>
            <Label Content="  Онлайн: "/>
            <Label x:Name="lblCount" Content="0" FontWeight="Bold" Foreground="Blue"/>
        </StackPanel>

        <ListBox x:Name="lstLog" Grid.Row="1" FontFamily="Consolas" FontSize="12"/>
    </Grid>
</Window>